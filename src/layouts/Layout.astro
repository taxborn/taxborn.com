---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<!-- TODO -->
		<!-- <meta name="description" content="Astro description" /> -->
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Braxton (taxborn) Fair</title>
	</head>
	<body class="font-mono p-4 bg-base text-text" id="body">
		<header>
			<div class="flex justify-between font-bold text-md md:text-lg">
				<p>TAXBORN(1)</p>
				<h1>Braxton <span class="text-mauve">Fair</span></h1>
				<p>TAXBORN(1)</p>
			</div>
		</header>

		<slot />
	</body>
</html>

<script>
	const body = document.getElementById("body");
	const scrollValue = 24; // Roughly the line height, seems the best to 'scroll' by one line

	body?.addEventListener("keypress", (event) => {
		if (event.key == 'j') window.scrollBy(0, scrollValue);
		if (event.key == 'k') window.scrollBy(0, -scrollValue);
	});
</script>

<style is:global>
	span.cursor {
		animation: fadeInOut 1.25s linear;
		animation-fill-mode: forwards;
		animation-iteration-count: infinite;
	}

	@keyframes fadeInOut {
		0% { opacity: 0; }
		50% { opacity: 100; }
		100% { opacity: 0; }
	}

	a {
		@apply underline underline-offset-4;
	}

	a:hover {
		@apply text-mauve;
	}
</style>
