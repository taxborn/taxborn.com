---
import Head from "@components/Head.astro";
import Navigation from "@components/Navigation.astro";
import Footer from "@components/Footer.astro";

interface Props {
	title: string,
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<Head title={title} />

	<body>
		<div class="container mx-auto max-w-3xl p-2 text-lg">
			<header>
				<Navigation />
			</header>

			<main class="py-2">
				<slot />
			</main>

			<Footer />
		</div>
	</body>
</html>

<style is:global>
	a {
		@apply underline underline-offset-2;
	}
</style>