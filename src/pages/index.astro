---
import Main from "../layouts/Main.astro";
---

<Main title="home">
	<h1>About me</h1>
	<p>👋 Hello there! My name is <b>Braxton Fair</b>, and I am a <span id="year" class="font-bold"></span> year old software engineer based out of 📍 Minneapolis, MN interested in APIs and working on the tools that enable developers to innovate.</p>
	<ul>
		<li>Test</li>
		<li>Test</li>
		<li>Test</li>
	</ul>
	<p>I graduated from <a href="https://mnsu.edu">Minnesota State University, Mankato</a> with a degree in a Computer Science, minoring in Mathematics.</p>
</Main>

<script>
	const birthdate = new Date("2001-10-18T20:56:00-05:00");
	const today = new Date();

	var age = today.getFullYear() - birthdate.getFullYear();
	// If today is BEFORE the birth month / day, then subtract one as 
	// my birthday hasn't happened this year
	if (today.getMonth() <= birthdate.getMonth() && today.getDate() <= birthdate.getDate()) 
		age -= 1;

	const yearEl = document.getElementById("year") as HTMLElement;
	yearEl.innerHTML = age.toString();
</script>