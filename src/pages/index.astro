---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<h1 class="text-2xl font-semibold">
		<span class="text-green">root@taxborn.com</span>:<span class="text-blue"
			>~/dev</span
		>$ ./website<span class="font-black cursor">_</span>
	</h1>

	<p class="mt-2">
		Lorem ipsum dolor sit amet consectetur adipisicing elit. Impedit
		explicabo corrupti nesciunt harum. Consequatur nemo assumenda
		reprehenderit earum voluptates nihil placeat illum, hic doloremque natus
		dolores, accusamus molestias ullam obcaecati!
	</p>
</Layout>

<style>
	.cursor {
		opacity: 1;
		animation-name: fade;
		animation-duration: 1.25s;
		/* TODO: This is a fine start, but is pretty random. Make more fluent for a typing animation eventually */
		animation-timing-function: cubic-bezier(0.075, 0.82, 0.165, 1);
		animation-iteration-count: infinite;
	}

	@keyframes fade {
		0%,
		100% {
			opacity: 0;
		}
		50% {
			opacity: 1;
		}
	}
</style>
