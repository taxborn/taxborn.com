---
import Layout from "../layouts/Layout.astro";

import { getCollection } from "astro:content";

const allPosts = [
    ...(await getCollection("links", ({ data }) => {
        return data.isDraft === false;
    })),
    ...(await getCollection("notes", ({ data }) => {
        return data.isDraft === false;
    })),
];

const latestPosts = allPosts.sort(
    (a, b) => +b.data.publishDate - +a.data.publishDate,
);
---

<Layout>
    <ul>
        {
            latestPosts.map((p) => (
                <li>
                    <a
                        href={
                            p.collection === "links"
                                ? p.data.url
                                : `/notes/${p.slug}`
                        }
                    >
                        {p.data.title}
                    </a>
                    -
                    <time
                        datetime={p.data.publishDate.toISOString()}
                        class="text-text/50"
                    >
                        {p.data.publishDate.toDateString()}
                    </time>
                </li>
            ))
        }
    </ul>
</Layout>
