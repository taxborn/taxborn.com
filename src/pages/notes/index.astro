---
import Layout from "../../layouts/Layout.astro";

import { getCollection } from "astro:content";

const allBlogPosts = await getCollection("notes", ({ data }) => {
    return data.isDraft === false;
});
const latestPosts = allBlogPosts.sort(
    (a, b) => +b.data.publishDate - +a.data.publishDate,
);
---

<Layout>
    <h1>All notes</h1>

    <ul>
        {
            latestPosts.map((p) => (
                <li>
                    <a href={`/notes/${p.slug}`} class="hover:underline">
                        <time
                            datetime={p.data.publishDate.toISOString()}
                            class="text-text/50"
                        >
                            {p.data.publishDate.toDateString()}
                        </time>
                        {p.data.title}
                    </a>
                </li>
            ))
        }
    </ul>
</Layout>
